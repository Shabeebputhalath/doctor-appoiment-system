{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and authentication data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "avatar": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Professional details for medical staff",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "bio": { "type": "string" },
        "rating": { "type": "number" },
        "patientsCount": { "type": "integer" },
        "experience": { "type": "integer" },
        "availability": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["uid", "name", "specialization"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Medical consultation booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled", "Completed"] },
        "type": { "type": "string" },
        "amount": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Pending", "Refunded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "time", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System alerts and user notifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "createdAt"]
    },
    "CMSContent": {
      "title": "CMS Content",
      "description": "Dynamic landing page content",
      "type": "object",
      "properties": {
        "section": { "type": "string", "enum": ["hero", "testimonials", "faq", "services"] },
        "content": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["section", "content"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Medical professional details"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Consultation bookings"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notification logs"
    },
    "cms/{sectionId}": {
      "schema": "CMSContent",
      "description": "Landing page configuration"
    }
  }
}
